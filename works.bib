@article{rovithis-livaniouStudyPeriodChanges2000,title={Study of the period changes of {X} {Trianguli}},volume={354},abstract={In the present study the (O-C) diagram of the eclipsing binary X Tri is used to study its orbital period behaviour. From our analysis, which is based on the description of the (O-C) diagram using weighted, high-order polynomials, it is shown that the period changes of X Tri (at least those after 1949) can be explained as due either to magnetic activity cycles or to a third companion on the subgiant G3IV cool secondary component. The elements of this hypothetical third body were computed and from their values it was found that it cannot coincide with the already known, visual companion. Moreover, if the period variations of X Tri are coming from the magnetic activity of the subgiant component of the binary, the subsurface magnetic field was found to be equal to 8.77 kG.},journal={Astronomy and Astrophysics},author={Rovithis-Livaniou, H. and Kranidiotis, Athanasios and Rovithis, P. and Athanassiades, G.},month={jan},year={2000},pages={904--908},file={Full Text PDF:/home/nassoskranidiotis/Zotero/storage/NGCKFZZB/Rovithis-Livaniou et al. - 2000 - Study of the period changes of X Trianguli.pdf:application/pdf}}
,
